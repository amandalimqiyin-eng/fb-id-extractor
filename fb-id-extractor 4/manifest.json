{
  "manifest_version": 3,
  "name": "FB ID Extractor",
  "version": "1.0",
  "description": "Extract Facebook Page ID and Post ID from any Facebook post",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["https://www.facebook.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
